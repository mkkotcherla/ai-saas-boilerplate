# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME="AI SaaS Boilerplate"

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/ai_saas?schema=public"
DIRECT_URL="postgresql://postgres:password@localhost:5432/ai_saas?schema=public"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Auth (NextAuth.js) ───────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-nextauth-secret-min-32-chars

# ─── OAuth Providers ──────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM="noreply@yourdomain.com"

# ─── AI Providers ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_AI_PROVIDER=openai
DEFAULT_AI_MODEL=gpt-4o-mini

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key

# Stripe Price IDs
STRIPE_PRICE_FREE=price_free
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly
STRIPE_PRICE_PRO_YEARLY=price_pro_yearly
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_enterprise_monthly

# ─── Vector DB (pgvector) ─────────────────────────────────────────────────────
VECTOR_DB_URL="postgresql://postgres:password@localhost:5432/ai_saas?schema=public"

# ─── Storage (S3-compatible) ──────────────────────────────────────────────────
S3_BUCKET=ai-saas-files
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
S3_ENDPOINT=https://s3.amazonaws.com

# ─── FastAPI Backend ──────────────────────────────────────────────────────────
API_SECRET_KEY=your-super-secret-api-key-min-32-chars
API_ACCESS_TOKEN_EXPIRE_MINUTES=30
API_REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# ─── Observability ────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
LOG_LEVEL=info

# ─── Feature Flags ────────────────────────────────────────────────────────────
ENABLE_MULTI_TENANT=true
ENABLE_AI_AGENTS=true
ENABLE_KNOWLEDGE_BASE=true
ENABLE_MARKETPLACE=false
