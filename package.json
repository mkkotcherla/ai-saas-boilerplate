{
  "name": "ai-saas-boilerplate",
  "version": "1.0.0",
  "private": true,
  "description": "Production-grade AI SaaS Boilerplate — Turborepo + Next.js 15 + FastAPI + Prisma + Stripe",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\" --ignore-path .gitignore",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "clean": "turbo clean && find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:push": "turbo db:push",
    "db:studio": "turbo db:studio",
    "db:seed": "tsx scripts/seed.ts",
    "setup": "bash scripts/setup.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^9.15.0",
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3",
    "tsx": "^4.19.1",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10"
  },
  "workspaces": ["apps/*", "packages/*"],
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": ["eslint --fix", "prettier --write"],
    "*.{json,md,yml,yaml}": ["prettier --write"]
  }
}
